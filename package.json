{
  "name": "cc-pet-web",
  "private": true,
  "scripts": {
    "kill:dev": "bash scripts/kill-local-dev.sh",
    "predev:server": "bash scripts/kill-local-dev.sh --server-only",
    "predev:web": "bash scripts/kill-local-dev.sh --web-only",
    "dev:server": "CC_PET_DATA_DIR=\"$INIT_CWD/.data\" pnpm --filter @cc-pet/server dev",
    "dev:web": "pnpm --filter @cc-pet/web dev",
    "dev": "bash scripts/run-dev.sh",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @cc-pet/server test -- tests/e2e-connect-regression.test.ts && pnpm --filter @cc-pet/web test -- src/App.integration.test.tsx",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "workspaces": [
    "packages/*"
  ]
}
