{
  "$schema": "https://raw.githubusercontent.com/nicepkg/gpt-runner/refs/heads/main/packages/gpt-runner-web/src-tauri/gen/schemas/desktop-schema.json",
  "productName": "CC Pet",
  "version": "0.1.2",
  "identifier": "com.ccpet.web",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "CC Pet",
        "width": 200,
        "height": 220,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true
      }
    ],
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
